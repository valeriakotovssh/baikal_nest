<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Baikal Nest</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('partials/header', { admin: true }) %>
  <main class="admin-page">
    <nav class="admin-nav"><a href="/admin">Дашборд</a><a href="/admin/bookings">Бронирования</a><a href="/admin/restaurant">Ресторан</a><a href="/admin/reviews">Отзывы</a><a href="/admin/calendar">Календарь</a></nav>
    <div class="calendar-toolbar">
      <div class="month-switch">
        <a href="/admin/calendar?month=<%= prevMonth %>">‹</a>
        <strong><%= monthTitle %></strong>
        <a href="/admin/calendar?month=<%= nextMonth %>">›</a>
      </div>
      <div class="legend"><span></span> Доступно <b></b> Занято</div>
      <a class="dark-button" href="/catalog">+ Новое бронирование</a>
    </div>
    <div class="calendar-table-wrap">
      <table class="calendar-table">
        <thead>
          <tr><th>№ Домика</th><% days.forEach((day) => { %><th><%= day %></th><% }) %></tr>
        </thead>
        <tbody>
          <% houses.forEach((house) => { %>
            <tr>
              <th><%= house.id %></th>
              <% days.forEach((day) => {
                const date = monthParam + '-' + String(day).padStart(2, '0');
                const dayBookings = bookings.filter((item) => item.house_id === house.id && item.start_date <= date && item.end_date > date);
                const booking = dayBookings[0];
                const isBookingStart = booking && booking.start_date === date;
                const isVisibleBookingStart = booking && (isBookingStart || day === 1);
                const nextDate = monthParam + '-' + String(day + 1).padStart(2, '0');
                const isBookingEnd = booking && booking.end_date === nextDate;
                const visibleBookingDays = booking ? Math.max(1, Math.min(
                  Math.ceil((new Date(`${booking.end_date}T00:00:00`) - new Date(`${date}T00:00:00`)) / 86400000),
                  days.length - day + 1
                )) : 1;
                const formatCalendarDate = (value) => new Date(value).toLocaleDateString('ru-RU');
                const calendarStatusLabels = {
                  new: 'Ожидает подтверждения',
                  confirmed: 'Подтверждена',
                  cancelled: 'Отменена',
                };
              %>
                <td class="<%= booking ? `busy calendar-status_${booking.status} ${isVisibleBookingStart ? 'booking-start' : 'booking-middle'} ${isBookingEnd ? 'booking-end' : ''}` : 'free' %>">
                  <% if (booking && isVisibleBookingStart) { %>
                    <a class="calendar-booking" style="--booking-days: <%= visibleBookingDays %>" href="/admin/bookings#booking-<%= booking.id %>" title="<%= booking.guest_name %>, <%= formatCalendarDate(booking.start_date) %>-<%= formatCalendarDate(booking.end_date) %>, <%= calendarStatusLabels[booking.status] || booking.status %>">
                      <em>Бронь №<%= booking.id %></em>
                      <strong><%= booking.guest_name %></strong>
                      <span><%= booking.title %></span>
                      <span><%= formatCalendarDate(booking.start_date) %>-<%= formatCalendarDate(booking.end_date) %></span>
                      <span><%= calendarStatusLabels[booking.status] || booking.status %></span>
                      <% if (dayBookings.length > 1) { %>
                        <em>+<%= dayBookings.length - 1 %></em>
                      <% } %>
                      <small>Подробнее</small>
                    </a>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
