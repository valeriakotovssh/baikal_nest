<div class="table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>№</th>
        <th>Имя</th>
        <th>Телефон</th>
        <th>Домик</th>
        <th>Даты</th>
        <th>Гости</th>
        <th>Пожелания</th>
        <th>Статус</th>
        <th>Действие</th>
      </tr>
    </thead>
    <tbody>
      <% bookings.forEach((booking) => { %>
        <tr>
          <td><%= booking.id %></td>
          <td><%= booking.guest_name %></td>
          <td><%= booking.phone %></td>
          <td><%= booking.title %></td>
          <td><%= formatDate(booking.start_date) %>-<%= formatDate(booking.end_date) %></td>
          <td><%= booking.guests %></td>
          <td class="table-note"><%= booking.message || '—' %></td>
          <td><%= statusLabel(booking.status) %></td>
          <td class="table-actions">
            <form action="/admin/bookings/<%= booking.id %>/status" method="post">
              <input type="date" name="start_date" value="<%= booking.start_date %>">
              <input type="date" name="end_date" value="<%= booking.end_date %>">
              <select name="status">
                <option value="new" <%= booking.status === 'new' ? 'selected' : '' %>>Ожидает подтверждения</option>
                <option value="confirmed" <%= booking.status === 'confirmed' ? 'selected' : '' %>>Подтверждена</option>
                <option value="paid" <%= booking.status === 'paid' ? 'selected' : '' %>>Оплачено</option>
                <option value="cancelled" <%= booking.status === 'cancelled' ? 'selected' : '' %>>Отменена</option>
              </select>
              <button class="outline-button" type="submit">Сохранить</button>
            </form>
            <form action="/admin/bookings/<%= booking.id %>/delete" method="post">
              <button class="dark-button" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
